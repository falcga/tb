# Jina AI API Configuration
# Copy this file to .env and fill in your values
# Get your free API key from https://jina.ai/reader

# Required for higher rate limits (optional - works anonymously without it)
JINA_API_KEY=jina_your_token_here

# Alternative variable name (also supported)
# JINA_TOKEN=jina_your_token_here

# Optional context token for session tracking
# JINA_CONTEXT_TOKEN=your_context_token_here